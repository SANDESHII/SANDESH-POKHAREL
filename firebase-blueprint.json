{
  "entities": {
    "TeamState": {
      "title": "Team State",
      "description": "Tracks team latent ability over time",
      "type": "object",
      "properties": {
        "estimatedNpxG": { "type": "number" },
        "variance": { "type": "number" },
        "lastUpdate": { "type": "string" },
        "volatility": { "type": "number" }
      },
      "required": ["estimatedNpxG", "variance", "lastUpdate", "volatility"]
    },
    "ModelMetadata": {
      "title": "Model Metadata",
      "description": "Weights and stats for ensemble models",
      "type": "object",
      "properties": {
        "weights": { "type": "array" },
        "lastTrained": { "type": "string" },
        "logLoss": { "type": "number" }
      },
      "required": ["weights", "lastTrained", "logLoss"]
    }
  },
  "firestore": {
    "/teamStates/{teamId}": {
      "schema": "TeamState",
      "description": "Collection of team latent states"
    },
    "/modelMetadata/{modelId}": {
      "schema": "ModelMetadata",
      "description": "Collection of model weights and metadata"
    }
  }
}
